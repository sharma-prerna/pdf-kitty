# ----- PostgreSQL -----
POSTGRES_DB=pdftoolkit
POSTGRES_USER=pdftoolkit
POSTGRES_PASSWORD=pdftoolkit

# ----- Backend -----
# Spring datasource (used inside docker-compose network)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/pdftoolkit
SPRING_DATASOURCE_USERNAME=pdftoolkit
SPRING_DATASOURCE_PASSWORD=pdftoolkit
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# File storage (inside backend container)
STORAGE_BASE_DIR=/data/storage
MAX_FILE_SIZE_MB=50
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# JWT (ready, not enforced yet)
JWT_SECRET=change-me-please-change-me-please-change-me-32+
JWT_EXPIRATION_MS=3600000

# ----- Frontend -----
# Nginx proxies /api to this upstream
BACKEND_UPSTREAM=http://backend:8080
